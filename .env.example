# Supabase project reference ID — the subdomain of your project URL
# (e.g. "abcdefgh" for https://abcdefgh.supabase.co). Found in Project Settings > General.
VITE_SUPABASE_PROJECT_ID="your-project-id"

# Supabase publishable (anon) key — the public client-side key.
# Safe to ship in the frontend bundle; access is enforced by Row Level Security.
# Found in Project Settings > API > Project API keys (anon / public).
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-anon-key"

# Supabase project API URL — https://<project-id>.supabase.co
# Found in Project Settings > API > Project URL.
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# Domain used to synthesize login emails from phone numbers (users sign in by phone;
# Supabase auth requires an email, so we store "<digits>@<this-domain>"). Optional —
# defaults to "phone.payroll.internal". The ".internal" suffix is reserved and never
# routes real mail; these are identifiers only.
#
# If you change this, you MUST keep all three in sync or existing users get locked out:
#   1. VITE_PHONE_EMAIL_DOMAIN here (frontend),
#   2. PHONE_EMAIL_DOMAIN in the Supabase edge function secrets, and
#   3. existing auth.users rows (add a migration like the one that ships in
#      supabase/migrations/*_neutralize_phone_email_domain.sql).
VITE_PHONE_EMAIL_DOMAIN="phone.payroll.internal"
